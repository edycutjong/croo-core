{
  "name": "@edycutjong/croo-core",
  "version": "0.1.3",
  "description": "Shared CROO SDK wrapper for the Constellation agent suite",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high || true",
    "ci": "npm run audit && npm run lint && npm run typecheck && npm run test",
    "prepublishOnly": "npm run ci && npm run build"
  },
  "keywords": [
    "croo",
    "agent",
    "a2a",
    "web3"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edycutjong/croo-core.git"
  },
  "bugs": {
    "url": "https://github.com/edycutjong/croo-core/issues"
  },
  "homepage": "https://github.com/edycutjong/croo-core#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.0.0",
    "license-checker": "^25.0.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "@croo-network/sdk": "^0.2.1"
  }
}

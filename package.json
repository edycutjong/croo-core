{
  "name": "croo-core",
  "version": "0.1.0",
  "description": "Shared CROO SDK wrapper for the Constellation agent suite",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["croo", "agent", "a2a", "web3"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "eslint": "^9.0.0"
  },
  "peerDependencies": {
    "@croo-network/sdk": ">=0.1.0"
  }
}
